{
    "compilerOptions": {
        "checkJs": true,
        "noEmit": true,
        "target": "ES2023",
        "lib": [
            "ES2023",
            "DOM"
        ],
        // TODO: Try changing these to true later on.
        "strict": false,
        "strictNullChecks": false,
        "useUnknownInCatchVariables": false,
        "noImplicitAny": true
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ],
    "include": [
        "src/**/*.js"
    ]
}